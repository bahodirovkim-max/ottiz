generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LANDLORD
  TENANT
  ADMIN
}

enum PaymentStatus {
  PENDING
  UNDER_REVIEW
  PAID
  FAILED
  OVERDUE
}

enum AgreementStatus {
  PENDING
  ACTIVE
  REJECTED
  ENDED
}

model User {
  id         String   @id @default(uuid())
  phone      String   @unique
  name       String?
  cardNumber String?
  role       Role     @default(TENANT)
  trustScore Int      @default(100)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  properties  Property[]      @relation("LandlordProperties")
  agreements  RentAgreement[] @relation("TenantAgreements")
}

model Property {
  id          String   @id @default(uuid())
  name        String
  address     String?
  price       Float
  currency    String   @default("UZS")
  landlordId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  landlord    User            @relation("LandlordProperties", fields: [landlordId], references: [id])
  agreements  RentAgreement[]

  @@index([landlordId])
}

model RentAgreement {
  id            String   @id @default(uuid())
  propertyId    String
  tenantId      String
  startDate     DateTime
  endDate       DateTime?
  monthlyAmount Float
  currency      String   @default("UZS")
  
  paymentDay    Int      @default(1)
  deposit       Float?
  discountAmount Float?

  isActive      Boolean  @default(true)
  status        AgreementStatus @default(PENDING)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property      Property  @relation(fields: [propertyId], references: [id])
  tenant        User      @relation("TenantAgreements", fields: [tenantId], references: [id])
  payments      Payment[]

  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
}

model Payment {
  id            String        @id @default(uuid())
  agreementId   String
  amount        Float
  currency      String        @default("UZS")
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  paymentMethod String?
  paymentType   String        @default("RENT") // RENT, UTILITY, DEPOSIT
  title         String?       // E.g. Svet, Gaz
  paidAmount    Float?        // Exact amount paid (if discount applied)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  agreement     RentAgreement @relation(fields: [agreementId], references: [id])

  @@index([agreementId])
  @@index([status])
  @@index([dueDate])
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}
